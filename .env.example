# ============================================================================
# FMCG Sales OS — Environment Variables
# ============================================================================
# Copy ke `.env.local` dan isi dengan kredensial milik Anda.
# JANGAN commit `.env.local` ke git.

# --- InsForge (WAJIB) ---
# Ambil dari dashboard InsForge atau panggil get-anon-key MCP tool.
NEXT_PUBLIC_INSFORGE_URL=https://4y8jtr73.ap-southeast.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Cookie session ---
# Nama cookie httpOnly tempat kita menyimpan InsForge access token.
# Tidak rahasia, tapi konsisten antara dev & prod.
SESSION_COOKIE=fmcg_session

# --- (opsional) AI ---
# Saat report generator real diaktifkan, isi key OpenRouter di sini (server-side).
# OPENROUTER_API_KEY=
